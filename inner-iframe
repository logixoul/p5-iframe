<!--
No file extension, because CloudFlare redirects foo.html to foo anyway
(and this redirect was messing up our loading logic
 -->
<!DOCTYPE html>
<html lang="en">
<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Inner p5 Runtime</title>
		<style>
				html,
				body {
						margin: 0;
						width: 100%;
						height: 100%;
						overflow: hidden;
				}

				#runtimeRoot,
				#runtimeFrame {
						width: 100%;
						height: 100%;
						border: 0;
						display: block;
				}
		</style>
</head>
<body>
		<div id="runtimeRoot"></div>

		<script>
				const runtimeRoot = document.getElementById("runtimeRoot");
				let runtimeFrame = null;

				function buildRuntimeDoc(userCode) {
						const codeString = JSON.stringify(String(userCode || ""));
						return `<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<style>
		html, body {
			margin: 0;
			width: 100%;
			height: 100%;
			overflow: hidden;
		}
		main {
			width: 100%;
			height: 100%;
		}
		canvas {
			display: block;
		}
	</style>
</head>
<body>
	<main id="app"></main>
	<script>
		function send(type, message) {
			parent.postMessage({ type: type, message: message }, "*");
		}

		const originalConsoleError = console.error;
		console.error = function (...args) {
			const message = args.length ? String(args[0]) : "Runtime error";
			send("runtime-error", message);
			originalConsoleError.apply(console, args);
		};

		window.addEventListener("error", function (event) {
			send("runtime-error", event.message || "Runtime error");
		});

		window.addEventListener("unhandledrejection", function (event) {
			const reason = event && event.reason ? event.reason : "Unhandled promise rejection";
			send("runtime-error", String(reason.message || reason));
		});
	<\/script>
	<script src="https://cdn.jsdelivr.net/npm/p5@2.3.0/lib/p5.min.js"><\/script>
	<script>
		try {
			const userCode = ${codeString};
			const tag = document.createElement("script");
			tag.type = "text/javascript";
			tag.text = userCode;
			document.body.appendChild(tag);
			send("runtime-ok", "Sketch loaded");
		} catch (error) {
			send("runtime-error", error.message || String(error));
		}
	<\/script>
</body>
</html>`;
				}

				function hardResetAndRun(code) {
						if (runtimeFrame) {
								runtimeFrame.remove();
								runtimeFrame = null;
						}

						const frame = document.createElement("iframe");
						frame.id = "runtimeFrame";
						frame.setAttribute("allow", "accelerometer; gyroscope; magnetometer");
						frame.setAttribute("sandbox", "allow-scripts");
						frame.setAttribute("title", "Runtime sandbox");
						frame.srcdoc = buildRuntimeDoc(code);
						runtimeRoot.appendChild(frame);
						runtimeFrame = frame;
				}

				window.addEventListener("message", (event) => {
						const data = event.data;
						if (!data || typeof data !== "object") {
								return;
						}
						if (data.type === "runtime-ok" || data.type === "runtime-error") {
								parent.postMessage(data, "*");
								return;
						}
						if (data.type === "run-sketch") {
								hardResetAndRun(data.code);
						}
				});

				parent.postMessage({ type: "runner-ready" }, "*");
		</script>
</body>
</html>
